<div class="container">
    <%# beginning form tag %>
    <%# data: {turbo: false} -> buat tampilin data yg diinput di dlm web %>
    <div class="row justify-content-center">
        <div class="col-10">
            <%= render 'shared/errors', obj: @user %>
            <%= form_with(model: @user, local: true, class: "shadow p-5 mb-4 bg-secondary rounded") do |f| %>
                <div class="form-group row">
                    <%= f.label :username, class:"col-2 col-form-label text-white" %>
                    <div class="col-10">
                        <%= f.text_field :username, class:"form-control shadow rounded", placeholder: "Enter a username"%>
                    </div>
                </div>

                <br>

                <div class="form-group row">
                    <%= f.label :email, class:"col-2 col-form-label text-white" %>
                    <div class="col-10">
                        <%= f.email_field :email, class:"form-control shadow rounded", placeholder: "Enter your email address" %>
                    </div>
                </div>

                <br>

                <div class="form-group row">
                    <%= f.label :password, class:"col-2 col-form-label text-white" %>
                    <div class="col-10">
                        <%= f.password_field :password, class:"form-control shadow rounded", placeholder: "Choose a password" %>
                    </div>
                </div>

                <br>

                <div class="form-group text-center">
                    <%= f.submit "Sign Up", class:"btn btn-success btn-outline-light btn-lg"%>
                </div>
            <% end %>
        </div>
        <div class="mb-3">
            <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-primary d-flex justify-content-center"%>
        </div>
    </div>
</div>